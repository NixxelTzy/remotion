{
  "version": 2,
  "buildCommand": null,
  "builds": [
    {
      "src": "api/render.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/render",
      "dest": "/api/render.js"
    }
  ],
  "functions": {
    "api/render.js": {
      "memory": 1024,
      "maxDuration": 300
    }
  },
  "cleanUrls": true
}

